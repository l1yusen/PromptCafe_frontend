{
  "openapi": "3.0.3",
  "info": {
    "title": "PromptCafe — Prompt 管理模块 API",
    "description": "基于组内约定整理：REST + `/api` 前缀；成功体为 `data`，失败体为 `error: { code, message }`；鉴权为 `Authorization: Bearer <JWT>`。\n\n**相对原《默认模块.openapi.json》的主要修订：**\n- 修正 `PUT /api/prompts/{id}` 将请求体误写在 `responses` 中的问题，改为正确的 `requestBody`。\n- 标签接口改为 **`PUT /api/prompts/{id}/tags`**，请求体为 **标签数组全量替换**（与产品约定一致），移除单标签 `POST`。\n- 移除 **文件夹**（`folderId`）、**个人 Prompt 收藏筛选**（`isFavorite`，收藏属社区模块）、**回收站/软删**（`includeDeleted`，当前为物理删除）。\n- 列表查询：`tags` 支持多值时建议使用重复键或逗号分隔（见参数说明）；分页推荐 `page` + `pageSize`。\n- 创建接口明确 **必填**：`title`、`userPrompt`（对应库表 `user_prompt`）。\n- 统一补充 **401/403/404/422** 等响应与 **Bearer** 安全方案。\n- `POST /api/prompts/{id}/copy` 为可选扩展能力，若本期不做可从实现中省略。\n\n**说明：** `POST /api/prompts/render` 仅根据请求体中的**未渲染** `systemPrompt` / `userPrompt` 与 `variables` 做占位符替换并返回结果，**不调大模型**、**不查库**、**不需要 `promptId`**，便于编辑页随时预览。\n- **variables[]**（Prompt 资源上）：仅 `text` / `textarea` / `number` 三种控件类型；`description` 为表单项说明；每项可含 `value`（默认/示例取值）。",
    "version": "1.3.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "与前端同源或由网关反代；本地开发可配 `http://localhost:8000`"
    }
  ],
  "tags": [
    {
      "name": "Prompts",
      "description": "个人 Prompt 的增删改查、渲染预览、标签全量替换"
    }
  ],
  "paths": {
    "/api/prompts": {
      "get": {
        "tags": ["Prompts"],
        "summary": "获取当前用户的 Prompt 列表（摘要）",
        "description": "仅返回当前登录用户拥有的 Prompt **摘要字段**，正文等大字段在详情接口获取。默认按 `updatedAt` 倒序。",
        "operationId": "listMyPrompts",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "按标题模糊搜索（可选）",
            "required": false,
            "schema": { "type": "string", "maxLength": 200 }
          },
          {
            "name": "tags",
            "in": "query",
            "description": "按标签筛选：多个标签时 **AND** 语义（同时包含）；传参方式二选一——重复 `tags=a&tags=b`，或 `tags=a,b`（实现择一支持即可，需在接口文档/README 写死）。",
            "required": false,
            "schema": { "type": "string" },
            "examples": {
              "repeat": { "value": "总结", "summary": "单标签" },
              "csv": { "value": "总结,写作", "summary": "逗号分隔多标签" }
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "排序字段",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["createdAt", "updatedAt", "title"],
              "default": "updatedAt"
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "desc"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码，从 1 开始",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptList" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        },
        "security": [{ "bearerAuth": [] }]
      },
      "post": {
        "tags": ["Prompts"],
        "summary": "创建 Prompt",
        "operationId": "createPrompt",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PromptCreateRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "已创建",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/prompts/{id}": {
      "get": {
        "tags": ["Prompts"],
        "summary": "获取 Prompt 详情",
        "operationId": "getPromptById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptDetail" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": [] }]
      },
      "put": {
        "tags": ["Prompts"],
        "summary": "更新 Prompt",
        "description": "部分更新：仅提交需要修改的字段即可。业务规则：`title` 与 `userPrompt` 若出现在 body 中则 **不能为空字符串**（与需求「标题与内容非空」一致）。更新成功后由版本模块策略决定是否生成新版本快照（见版本接口文档）。",
        "operationId": "updatePrompt",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PromptUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        },
        "security": [{ "bearerAuth": [] }]
      },
      "delete": {
        "tags": ["Prompts"],
        "summary": "删除 Prompt（物理删除）",
        "description": "删除当前用户拥有的 Prompt；**版本表一并删除**；社区快照若已存在则保留（与组内约定一致，源 `prompt_id` 外键需 SET NULL 或等价处理）。**不可恢复。**",
        "operationId": "deletePrompt",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "已删除，无响应体" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/prompts/{id}/copy": {
      "post": {
        "tags": ["Prompts"],
        "summary": "复制 Prompt（可选）",
        "description": "在原稿基础上创建副本；若本期不实现可返回 **501** 或直接不提供该路由。",
        "operationId": "copyPrompt",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "副本标题，默认：原标题 + 「 - 副本」"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "已创建副本",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptDetail" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "501": {
            "description": "未实现",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" }
              }
            }
          }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/prompts/render": {
      "post": {
        "tags": ["Prompts"],
        "summary": "变量渲染预览（不调模型、不查库）",
        "description": "根据请求体中的 **未渲染** 模板与 `variables` 做占位符替换（如 `{{name}}` → 对应取值），返回 **渲染后的** `systemPrompt` / `userPrompt` 文本。用于创建/编辑页随时预览，**无需**已保存的 `promptId`。**不调用大模型**。",
        "operationId": "renderPromptPreview",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PromptRenderRequest" },
              "examples": {
                "both": {
                  "summary": "系统区与用户区均有占位符",
                  "value": {
                    "systemPrompt": "你是{{role}}",
                    "userPrompt": "请总结：{{content}}",
                    "variables": { "role": "助手", "content": "一段待处理文本" }
                  }
                },
                "userOnly": {
                  "summary": "仅用户提示词（system 可省略）",
                  "value": {
                    "systemPrompt": null,
                    "userPrompt": "总结：{{content}}",
                    "variables": { "content": "正文" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptRender" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        },
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/prompts/{id}/tags": {
      "put": {
        "tags": ["Prompts"],
        "summary": "全量替换 Prompt 标签",
        "description": "请求体为 **完整标签列表**；未出现在列表中的标签视为删除。空数组表示清空所有标签。",
        "operationId": "replacePromptTags",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TagsReplaceRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccessPromptDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "422": { "$ref": "#/components/responses/UnprocessableEntity" }
        },
        "security": [{ "bearerAuth": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "登录后签发的访问令牌"
      }
    },
    "responses": {
      "BadRequest": {
        "description": "请求参数错误",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" },
            "example": { "data": null, "error": { "code": "BAD_REQUEST", "message": "参数不合法" } }
          }
        }
      },
      "Unauthorized": {
        "description": "未认证或令牌失效",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" },
            "example": { "data": null, "error": { "code": "UNAUTHORIZED", "message": "请先登录" } }
          }
        }
      },
      "Forbidden": {
        "description": "无权限（非资源所有者等）",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" },
            "example": { "data": null, "error": { "code": "FORBIDDEN", "message": "无权访问该资源" } }
          }
        }
      },
      "NotFound": {
        "description": "资源不存在",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" },
            "example": { "data": null, "error": { "code": "NOT_FOUND", "message": "Prompt 不存在" } }
          }
        }
      },
      "UnprocessableEntity": {
        "description": "语义/业务校验失败",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ApiErrorEnvelope" },
            "example": { "data": null, "error": { "code": "VALIDATION_ERROR", "message": "标题不能为空" } }
          }
        }
      }
    },
    "schemas": {
      "ApiErrorBody": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "description": "机器可读错误码" },
          "message": { "type": "string", "description": "人类可读说明" }
        }
      },
      "ApiErrorEnvelope": {
        "type": "object",
        "required": ["data", "error"],
        "properties": {
          "data": { "nullable": true, "description": "失败时为 null" },
          "error": { "$ref": "#/components/schemas/ApiErrorBody" }
        }
      },
      "PromptVariableDef": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "description": "占位符名，如 `content` 对应模板中的 `{{content}}`" },
          "type": {
            "type": "string",
            "description": "创建/编辑页中该参数输入控件的类型（仅文本类，无下拉枚举）",
            "enum": ["text", "textarea", "number"],
            "default": "text"
          },
          "description": {
            "type": "string",
            "description": "给人看的说明文案，展示在表单项标题或提示旁；不参与占位符解析"
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "预览/测试/正式替换前，是否要求用户必须填写该参数（空 `value` 且未填则校验失败）"
          },
          "value": {
            "type": "string",
            "nullable": true,
            "description": "创建或编辑时可填的**默认/示例取值**，用于同页参数预览与后续测试预填；未填表示空字符串。`number` 类型也以字符串形式传输（如 `\"42\"`）"
          }
        }
      },
      "PromptSummary": {
        "type": "object",
        "required": ["id", "title", "currentVersion", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "currentVersion": { "type": "integer", "minimum": 1 },
          "visibility": {
            "type": "string",
            "enum": ["private", "public"],
            "description": "与库表一致；社区展示走社区快照，不依赖此字段单独暴露正文"
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "PromptDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/PromptSummary" },
          {
            "type": "object",
            "required": ["userPrompt"],
            "properties": {
              "systemPrompt": { "type": "string", "nullable": true },
              "userPrompt": { "type": "string" },
              "variables": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/PromptVariableDef" },
                "description": "变量定义 JSON，与库表 `variables` 一致"
              }
            }
          }
        ]
      },
      "PromptListData": {
        "type": "object",
        "required": ["items", "total", "page", "pageSize"],
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PromptSummary" }
          },
          "total": { "type": "integer", "minimum": 0 },
          "page": { "type": "integer", "minimum": 1 },
          "pageSize": { "type": "integer", "minimum": 1 }
        }
      },
      "ApiSuccessPromptList": {
        "type": "object",
        "required": ["data", "error"],
        "properties": {
          "data": { "$ref": "#/components/schemas/PromptListData" },
          "error": {
            "description": "成功时为 `null`（键仍存在，值为 null）",
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/ApiErrorBody" }]
          }
        }
      },
      "ApiSuccessPromptDetail": {
        "type": "object",
        "required": ["data", "error"],
        "properties": {
          "data": { "$ref": "#/components/schemas/PromptDetail" },
          "error": {
            "description": "成功时为 `null`",
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/ApiErrorBody" }]
          }
        }
      },
      "ApiSuccessPromptRender": {
        "type": "object",
        "required": ["data", "error"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["renderedSystemPrompt", "renderedUserPrompt"],
            "properties": {
              "renderedSystemPrompt": { "type": "string", "nullable": true },
              "renderedUserPrompt": { "type": "string" }
            }
          },
          "error": {
            "description": "成功时为 `null`",
            "nullable": true,
            "allOf": [{ "$ref": "#/components/schemas/ApiErrorBody" }]
          }
        }
      },
      "PromptCreateRequest": {
        "type": "object",
        "required": ["title", "userPrompt"],
        "properties": {
          "title": { "type": "string", "maxLength": 200 },
          "description": { "type": "string", "nullable": true },
          "systemPrompt": { "type": "string", "nullable": true },
          "userPrompt": { "type": "string" },
          "variables": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PromptVariableDef" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string", "maxLength": 64 }
          },
          "visibility": {
            "type": "string",
            "enum": ["private", "public"],
            "default": "private"
          }
        }
      },
      "PromptUpdateRequest": {
        "type": "object",
        "minProperties": 1,
        "properties": {
          "title": { "type": "string", "maxLength": 200 },
          "description": { "type": "string", "nullable": true },
          "systemPrompt": { "type": "string", "nullable": true },
          "userPrompt": { "type": "string" },
          "variables": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PromptVariableDef" }
          },
          "visibility": {
            "type": "string",
            "enum": ["private", "public"]
          }
        },
        "description": "至少包含一个字段；`title` / `userPrompt` 若出现则不能为空字符串。"
      },
      "PromptRenderRequest": {
        "type": "object",
        "description": "全部为**当前编辑区原文**（未做变量替换）。`variables` 为占位符名 → 替换用字符串；未出现的占位符是否保留原文或报错由后端约定（建议 422 明确提示缺键）。",
        "required": ["userPrompt", "variables"],
        "properties": {
          "systemPrompt": {
            "type": "string",
            "nullable": true,
            "description": "未渲染的系统提示词；无则传 `null` 或省略"
          },
          "userPrompt": {
            "type": "string",
            "description": "未渲染的用户提示词正文（允许空字符串，表示仅预览系统侧）"
          },
          "variables": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "description": "本次预览使用的变量取值表，例如 `{ \"content\": \"...\" }`"
          }
        }
      },
      "TagsReplaceRequest": {
        "type": "object",
        "required": ["tags"],
